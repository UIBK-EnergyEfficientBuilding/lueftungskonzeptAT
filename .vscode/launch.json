{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: dev.py",
            "type": "python",
            "request": "launch",
            "program": "dev.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Flask",
            "type": "python",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "lueftungstool/__init__.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
            ],
            "jinja": true,
            "justMyCode": true
        },
    ]
}